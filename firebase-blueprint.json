{
  "entities": {
    "Message": {
      "title": "Message",
      "description": "A chat message",
      "type": "object",
      "properties": {
        "text": { "type": "string", "description": "The message content" },
        "username": { "type": "string", "description": "The sender's username" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the message was sent" },
        "type": { "type": "string", "enum": ["message", "system"], "description": "Type of message" },
        "imageUrl": { "type": "string", "description": "Optional base64 image data" },
        "isEdited": { "type": "boolean", "description": "Whether the message was edited" }
      },
      "required": ["text", "username", "timestamp", "type"]
    },
    "ActiveUser": {
      "title": "ActiveUser",
      "description": "A user currently in the chat",
      "type": "object",
      "properties": {
        "username": { "type": "string", "description": "The unique username" },
        "lastSeen": { "type": "string", "format": "date-time", "description": "Last activity timestamp" }
      },
      "required": ["username", "lastSeen"]
    },
    "RegisteredUser": {
      "title": "RegisteredUser",
      "description": "A user registered with their real name",
      "type": "object",
      "properties": {
        "realName": { "type": "string", "description": "The user's real name" },
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "isMuted": { "type": "boolean", "description": "Whether the user is muted in chat" },
        "jumpscareTriggered": { "type": "boolean", "description": "Whether a jumpscare is triggered for this user" },
        "fullscreenTriggered": { "type": "boolean", "description": "Whether fullscreen is triggered for this user" },
        "imageScreenTriggered": { "type": "string", "description": "Image URL for image screen" },
        "registeredAt": { "type": "string", "format": "date-time", "description": "When the user registered" }
      },
      "required": ["realName", "uid", "isMuted", "registeredAt"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "A global or private announcement",
      "type": "object",
      "properties": {
        "text": { "type": "string", "description": "The announcement content" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When it was sent" },
        "targetUid": { "type": "string", "description": "Optional target user UID for private messages" }
      },
      "required": ["text", "timestamp"]
    },
    "Game": {
      "title": "Game",
      "description": "A user-uploaded game",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the game" },
        "thumbnail": { "type": "string", "description": "URL of the thumbnail" },
        "htmlContent": { "type": "string", "description": "The HTML code of the game" },
        "uploaderUid": { "type": "string", "description": "The UID of the user who uploaded the game" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the game was uploaded" }
      },
      "required": ["title", "thumbnail", "htmlContent", "uploaderUid", "createdAt"]
    }
  },
  "firestore": {
    "/messages": {
      "schema": "Message",
      "description": "Collection of chat messages"
    },
    "/active_users": {
      "schema": "ActiveUser",
      "description": "Collection of currently active users"
    },
    "/users": {
      "schema": "RegisteredUser",
      "description": "Collection of registered users"
    },
    "/announcements": {
      "schema": "Announcement",
      "description": "Collection of announcements"
    },
    "/games": {
      "schema": "Game",
      "description": "Collection of user-uploaded games"
    }
  }
}
