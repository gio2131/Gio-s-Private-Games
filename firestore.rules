// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: messages
// Fields:
//   - text: string (1-1000 chars) - The message content
//   - username: string (2-20 chars) - The sender's name
//   - timestamp: timestamp (required) - Server-side time
//   - type: string ('message' or 'system') - Message category
//
// Collection: active_users
// Fields:
//   - username: string (2-20 chars) - Unique identifier
//   - lastSeen: timestamp (required) - Heartbeat time
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isValidMessage(data) {
      return data.keys().hasAll(['text', 'username', 'timestamp', 'type']) &&
             data.text is string && data.text.size() <= 1000 &&
             data.username is string && data.username.size() >= 2 && data.username.size() <= 20 &&
             data.type in ['message', 'system'];
    }

    function isValidActiveUser(data) {
      return data.keys().hasAll(['username', 'lastSeen']) &&
             data.username is string && data.username.size() >= 2 && data.username.size() <= 20;
    }

    function isValidModeratedUser(data) {
      return data.keys().hasAll(['username', 'lastSeen', 'isMuted']) &&
             data.username is string && data.username.size() >= 2 && data.username.size() <= 20 &&
             data.isMuted is bool;
    }

    function isAdmin() {
      return isAuthenticated();
    }

    // Messages collection
    match /messages/{messageId} {
      allow read, write: if true;
    }

    // Active users collection
    match /active_users/{username} {
      allow read, write: if true;
    }

    // Users collection (for moderation)
    match /users/{userId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if isAdmin();
    }

    // Announcements collection
    match /announcements/{announcementId} {
      allow read, write: if true;
    }

    // Suggestions collection
    match /suggestions/{suggestionId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }

    // Games collection
    match /games/{gameId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }
  }
}
